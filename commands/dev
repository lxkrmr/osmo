#!/usr/bin/env bash
set -euo pipefail

resolve_script_dir() {
  local src="${BASH_SOURCE[0]}"
  while [ -h "$src" ]; do
    local dir
    dir="$(cd -P "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    [[ "$src" != /* ]] && src="$dir/$src"
  done
  cd -P "$(dirname "$src")" && pwd
}

SCRIPT_DIR="$(resolve_script_dir)"
DEVKIT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

resolve_repo_root() {
  local repo_path="${ODOO_REPO_PATH:-}"
  if [ -n "$repo_path" ] && [ -f "$repo_path/docker-compose.yml" ]; then
    cd "$repo_path" && pwd
    return
  fi

  if [ -f "./docker-compose.yml" ]; then
    pwd
    return
  fi

  local start
  start="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

  # Walk up to find docker-compose.yml
  local cur="$start"
  while [ "$cur" != "/" ]; do
    if [ -f "$cur/docker-compose.yml" ]; then
      echo "$cur"
      return
    fi
    cur="$(dirname "$cur")"
  done

  echo ""
}

ROOT_DIR="$(resolve_repo_root)"
if [ -z "$ROOT_DIR" ]; then
  echo "Could not resolve Odoo project repo root." >&2
  echo "Run from Odoo repo root or set ODOO_REPO_PATH=/path/to/odoo-project." >&2
  exit 1
fi

cd "$ROOT_DIR"

usage() {
  cat <<'EOF'
Usage: .pi/tools/dev <command> [args...]

Commands:
  up [services...]             Start docker services (docker compose up -d)
  db [psql args...]            Open psql using DB config from docker/odoo_*.conf
  shell [db_name]              Start Odoo shell (--no-http) in odoo container
  test [run-tests args...]     Run ./run-tests.sh with forwarded args
  lint [pre-commit args...]    Run pre-commit (defaults to run --all-files)
  doctor                       Run devkit bootstrap doctor checks
  components                   Show available/enabled devkit skills and commands
  enable-skill <name>          Enable one skill in current project
  disable-skill <name>         Disable one skill in current project
  enable-command <name>        Enable one command in current project
  disable-command <name>       Disable one command in current project
  new-skill <name>             Scaffold a new skill from template
  help                         Show this help

Examples:
  .pi/tools/dev up
  .pi/tools/dev db
  .pi/tools/dev db -c "SELECT COUNT(*) FROM res_partner;"
  .pi/tools/dev shell
  .pi/tools/dev shell postgres
  .pi/tools/dev test -u my_addon
  .pi/tools/dev lint
  .pi/tools/dev doctor
  .pi/tools/dev components
  .pi/tools/dev enable-skill browser-tools
  .pi/tools/dev disable-skill odoo-translate
  .pi/tools/dev enable-command dev
  .pi/tools/dev new-skill odoo-my-workflow
EOF
}

load_pg_env() {
  eval "$(python3 - <<'PY'
import configparser
from pathlib import Path

cfg = configparser.ConfigParser()
base = Path('docker/odoo_base.conf')
local = Path('docker/odoo_local.conf')
paths = [str(p) for p in (base, local) if p.exists()]
cfg.read(paths)
opt = cfg['options'] if cfg.has_section('options') else {}

vals = {
    'PGHOST': opt.get('db_host', 'localhost'),
    'PGPORT': opt.get('db_port', '5432'),
    'PGDATABASE': opt.get('db_name', 'postgres'),
    'PGUSER': opt.get('db_user', 'odoo'),
    'PGPASSWORD': opt.get('db_password', 'odoo'),
}

if vals['PGHOST'] in ('postgres', 'db'):
    vals['PGHOST'] = 'localhost'

for k, v in vals.items():
    v = str(v).replace('"', '\\"')
    print(f'export {k}="{v}"')
PY
)"
}

cmd_up() {
  docker compose up -d "$@"
}

cmd_db() {
  load_pg_env
  if command -v psql >/dev/null 2>&1; then
    psql "$@"
  else
    echo "psql not found locally; using postgres container psql"
    docker compose exec postgres psql -U "$PGUSER" -d "$PGDATABASE" "$@"
  fi
}

cmd_shell() {
  load_pg_env
  local db_name="${1:-${DATABASE:-$PGDATABASE}}"
  docker compose exec odoo odoo shell --no-http -d "$db_name"
}

cmd_test() {
  ./run-tests.sh "$@"
}

cmd_lint() {
  if [ "$#" -eq 0 ]; then
    pre-commit run --all-files
  else
    pre-commit run "$@"
  fi
}

cmd_doctor() {
  python3 "$DEVKIT_ROOT/bootstrap/doctor.py" "$ROOT_DIR"
}

cmd_components() {
  python3 - "$DEVKIT_ROOT" "$ROOT_DIR" <<'PY'
import json
import os
import sys
from pathlib import Path

DEVKIT = Path(sys.argv[1])
PROJECT = Path(sys.argv[2])

skills_root = DEVKIT / 'skills'
commands_root = DEVKIT / 'commands'
manifest_path = skills_root / 'manifest.json'
manifest = {}
if manifest_path.exists():
    try:
        manifest = json.loads(manifest_path.read_text(encoding='utf-8'))
    except Exception:
        manifest = {}

enabled_skills_dir = PROJECT / '.pi' / 'skills' / 'shared-devkit'
enabled_cmds_dir = PROJECT / '.pi' / 'tools' / 'shared-devkit'

def parse_skill_meta(skill_dir: Path):
    name = skill_dir.name
    desc = "No description"
    f = skill_dir / 'SKILL.md'
    if f.exists():
        try:
            lines = f.read_text(encoding='utf-8').splitlines()
            if lines and lines[0].strip() == '---':
                i = 1
                while i < len(lines) and lines[i].strip() != '---':
                    line = lines[i]
                    if line.startswith('name:'):
                        name = line.split(':', 1)[1].strip() or name
                    elif line.startswith('description:'):
                        desc = line.split(':', 1)[1].strip() or desc
                    i += 1
        except Exception:
            pass
    return name, desc

def eval_skill(name: str):
    entry = manifest.get(name, {})
    req = entry.get('requirements', {}) if isinstance(entry, dict) else {}
    reasons = []
    for rel in req.get('project_files', []):
        if not (PROJECT / rel).exists():
            reasons.append(f"missing file: {rel}")
    for rel in req.get('project_dirs', []):
        p = PROJECT / rel
        if not p.exists() or not p.is_dir():
            reasons.append(f"missing directory: {rel}")
    for cmd in req.get('commands', []):
        if not shutil.which(cmd):
            reasons.append(f"missing command: {cmd}")
    if reasons:
        return False, '; '.join(reasons)
    return True, ''

import shutil

all_skills = []
for d in sorted(skills_root.iterdir(), key=lambda p: p.name):
    if d.is_dir() and not d.name.startswith('_') and (d / 'SKILL.md').exists():
        n, desc = parse_skill_meta(d)
        ok, reason = eval_skill(n)
        all_skills.append((n, desc, ok, reason))

enabled_skills = set()
if enabled_skills_dir.exists() and enabled_skills_dir.is_dir():
    enabled_skills = {p.name for p in enabled_skills_dir.iterdir()}

available_cmds = []
for p in sorted(commands_root.iterdir(), key=lambda p: p.name):
    if p.is_file() and p.name != 'README.md' and os.access(p, os.X_OK):
        available_cmds.append((p.name, 'Helper command'))

enabled_cmds = set()
if enabled_cmds_dir.exists() and enabled_cmds_dir.is_dir():
    enabled_cmds = {p.name for p in enabled_cmds_dir.iterdir()}

print("\n🧰 Pi Odoo Devkit Components")
print(f"Project: {PROJECT}")
print(f"Devkit:  {DEVKIT}\n")

print("Skills:")
for name, desc, ok, reason in all_skills:
    if ok:
        mark = '✅' if name in enabled_skills else '⬜'
        print(f"  {mark} {name:28} {desc}")
    else:
        print(f"  ⛔ {name:28} {desc}  (unavailable: {reason})")
if not all_skills:
    print("  (none)")

print("\nCommands:")
for name, desc in available_cmds:
    mark = '✅' if name in enabled_cmds else '⬜'
    print(f"  {mark} {name:28} {desc}")
if not available_cmds:
    print("  (none)")

print("\nTips:")
print("  - Re-run wizard to change selection:")
print(f"    {DEVKIT}/pi-odoo-devkit.sh wizard {PROJECT}")
print("  - Run health checks:")
print("    ./.pi/tools/devkit doctor")
PY
}

_link_entry() {
  local src="$1"
  local dst="$2"

  mkdir -p "$(dirname "$dst")"
  if [ -e "$dst" ] || [ -L "$dst" ]; then
    rm -rf "$dst"
  fi
  ln -s "$src" "$dst"
}

cmd_enable_skill() {
  local name="${1:-}"
  if [ -z "$name" ]; then
    echo "Usage: .pi/tools/dev enable-skill <skill-name>" >&2
    return 1
  fi

  local src="$DEVKIT_ROOT/skills/$name"
  local marker="$src/SKILL.md"
  local dst="$ROOT_DIR/.pi/skills/shared-devkit/$name"

  if [ ! -f "$marker" ]; then
    echo "Skill not found in devkit: $name" >&2
    return 1
  fi

  local check
  check="$(python3 - "$DEVKIT_ROOT" "$ROOT_DIR" "$name" <<'PY'
import json
import shutil
import sys
from pathlib import Path

DEVKIT = Path(sys.argv[1])
PROJECT = Path(sys.argv[2])
NAME = sys.argv[3]

manifest = {}
mp = DEVKIT / 'skills' / 'manifest.json'
if mp.exists():
    try:
        manifest = json.loads(mp.read_text(encoding='utf-8'))
    except Exception:
        manifest = {}

entry = manifest.get(NAME, {})
req = entry.get('requirements', {}) if isinstance(entry, dict) else {}
reasons = []
for rel in req.get('project_files', []):
    if not (PROJECT / rel).exists():
        reasons.append(f"missing file: {rel}")
for rel in req.get('project_dirs', []):
    p = PROJECT / rel
    if not p.exists() or not p.is_dir():
        reasons.append(f"missing directory: {rel}")
for cmd in req.get('commands', []):
    if not shutil.which(cmd):
        reasons.append(f"missing command: {cmd}")

if reasons:
    print('FAIL:' + '; '.join(reasons))
else:
    print('OK')
PY
)"

  if [[ "$check" == FAIL:* ]]; then
    echo "Cannot enable skill '$name' (${check#FAIL:})" >&2
    return 1
  fi

  _link_entry "$src" "$dst"
  echo "✅ Enabled skill: $name"
}

cmd_disable_skill() {
  local name="${1:-}"
  if [ -z "$name" ]; then
    echo "Usage: .pi/tools/dev disable-skill <skill-name>" >&2
    return 1
  fi

  local dst="$ROOT_DIR/.pi/skills/shared-devkit/$name"
  if [ -e "$dst" ] || [ -L "$dst" ]; then
    rm -rf "$dst"
    echo "✅ Disabled skill: $name"
  else
    echo "Skill already disabled: $name"
  fi
}

cmd_enable_command() {
  local name="${1:-}"
  if [ -z "$name" ]; then
    echo "Usage: .pi/tools/dev enable-command <command-name>" >&2
    return 1
  fi

  local src="$DEVKIT_ROOT/commands/$name"
  local dst="$ROOT_DIR/.pi/tools/shared-devkit/$name"

  if [ ! -x "$src" ]; then
    echo "Command not found/executable in devkit: $name" >&2
    return 1
  fi

  _link_entry "$src" "$dst"
  echo "✅ Enabled command: $name"

  if [ "$name" = "dev" ]; then
    _link_entry "$ROOT_DIR/.pi/tools/shared-devkit/dev" "$ROOT_DIR/.pi/tools/devkit"
    echo "✅ Refreshed convenience link: .pi/tools/devkit"
  fi
}

cmd_disable_command() {
  local name="${1:-}"
  if [ -z "$name" ]; then
    echo "Usage: .pi/tools/dev disable-command <command-name>" >&2
    return 1
  fi

  if [ "$name" = "dev" ]; then
    echo "Refusing to disable 'dev' via this command. Use installer/uninstall if needed." >&2
    return 1
  fi

  local dst="$ROOT_DIR/.pi/tools/shared-devkit/$name"
  if [ -e "$dst" ] || [ -L "$dst" ]; then
    rm -rf "$dst"
    echo "✅ Disabled command: $name"
  else
    echo "Command already disabled: $name"
  fi
}

cmd_new_skill() {
  local name="${1:-}"
  if [ -z "$name" ]; then
    echo "Usage: .pi/tools/dev new-skill <skill-name>" >&2
    return 1
  fi

  if [[ ! "$name" =~ ^[a-z0-9][a-z0-9-]*$ ]]; then
    echo "Invalid skill name '$name'. Use lowercase letters, numbers, and dashes." >&2
    return 1
  fi

  local template target_dir target_file
  template="$DEVKIT_ROOT/templates/SKILL.md"
  target_dir="$DEVKIT_ROOT/skills/$name"
  target_file="$target_dir/SKILL.md"

  if [ ! -f "$template" ]; then
    echo "Template not found: $template" >&2
    return 1
  fi

  if [ -e "$target_file" ]; then
    echo "Skill already exists: $target_file" >&2
    return 1
  fi

  mkdir -p "$target_dir"
  cp "$template" "$target_file"

  # Fill minimal placeholders
  python3 - "$target_file" "$name" <<'PY'
import sys
from pathlib import Path

path = Path(sys.argv[1])
name = sys.argv[2]
text = path.read_text(encoding='utf-8')
text = text.replace('<skill-name>', name)
text = text.replace('<one-line purpose>', f'Describe the purpose of {name}.')
text = text.replace('<Skill Title>', name.replace('-', ' ').title())
path.write_text(text, encoding='utf-8')
PY

  echo "Created skill scaffold: $target_file"
  echo "Next steps:"
  echo "1) Edit file and replace remaining placeholders"
  echo "2) Add concrete steps + validation commands"
  echo "3) Keep Credential Hygiene section"
}

cmd="${1:-help}"
shift || true

case "$cmd" in
  up) cmd_up "$@" ;;
  db) cmd_db "$@" ;;
  shell) cmd_shell "$@" ;;
  test) cmd_test "$@" ;;
  lint) cmd_lint "$@" ;;
  doctor) cmd_doctor "$@" ;;
  components) cmd_components "$@" ;;
  enable-skill) cmd_enable_skill "$@" ;;
  disable-skill) cmd_disable_skill "$@" ;;
  enable-command) cmd_enable_command "$@" ;;
  disable-command) cmd_disable_command "$@" ;;
  new-skill) cmd_new_skill "$@" ;;
  help|-h|--help) usage ;;
  *)
    echo "Unknown command: $cmd" >&2
    echo
    usage
    exit 1
    ;;
esac
